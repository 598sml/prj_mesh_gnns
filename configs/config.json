{
  "experiment_name": "mgn_smoke_test_quickwandb_cluster",

  "seed": 5,
  "device": "cuda",
  
  "Change the dataset_source to dataset_colab to use the preprocessed data from Colab.": "dataset_source can be either 'dataset_colab' or 'dataset_local'", 
  "dataset_source": "dataset_colab", 

  "dataset_colab": {
    "file_path": "data/processed/data_pt/meshgraphnets_miniset5traj_vis.pt",
    "train_size": 45,
    "valid_size": 10,
    "shuffle_before_split": true
  },

  "paths": {
    "train_data": "data/processed/data_pt/train.pt",
    "valid_data": "data/processed/data_pt/valid.pt",
    "test_data": "data/processed/data_pt/test.pt",
    "checkpoint_dir": "outputs/checkpoints",
    "figure_dir": "outputs/figures",
    "one_step_dir": "outputs/figures/one_step",
    "rollout_dir": "outputs/figures/rollout_figures"
  },

  "data": {
    "use_subset": true,
    "train_subset_size": 500,
    "valid_subset_size": 90,
    "delta_t": 0.01,
    "noise_scale": 0.0,
    "noise_gamma": 1.0,
    "shuffle_train": true
  },

  "model": {
    "hidden_dim": 10,
    "num_layers": 10
  },

  "training": {
    "batch_size": 16,
    "learning_rate": 0.001,
    "weight_decay": 0.0005,
    "num_epochs": 5000
  },

  "evaluation": {
    "sample_indices": [0, 50, 100, 200, 300, 400, 500]
  },

  "rollout": {
    "split": "test",
    "train_traj_idx": 0,
    "sample_steps": [0, 50, 100, 200, 300, 400, 500]
  },

  "wandb": {
    "enabled": true,
    "project": "meshgraphnet-vortex",
    "run_name": "mgn_smoke_test_wandb_cluster"
  }
}